# Copy to .env (gitignored) and fill in real values.

# Switcher cloud relay. Find it by capturing the official Switcher phone app's
# network traffic while you control the AC (e.g. `pymobiledevice3 pcap` over USB,
# or Wireshark) and noting the IP:port it opens a TCP connection to. Keep secret.
CLOUD_IP=
CLOUD_PORT=

# Device identity (from scripts/discover_devices.py)
DEVICE_ID=
DEVICE_IP=
DEVICE_KEY=
REMOTE_ID=

# Cloud auth — capture from the phone app (see CLOUD-CONTROL.md). SECRET.
PHONE_ID=
LOGIN_AUTH=
CONTROL_AUTH=

# Optional: ESP32 DHT sensor endpoint (leave unset to use the Switcher's own temp)
# ESP_URL=http://<ESP_IP>/data
